{
  "name": "skermtime",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @skermtime/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
